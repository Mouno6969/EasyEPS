# --- Core ---
NODE_ENV=development

# MySQL connection (optional for guest curriculum-only mode)
# Example: mysql://user:password@127.0.0.1:3306/easyeps
DATABASE_URL=

# Session signing secret (required for signed-in sessions)
JWT_SECRET=change-me-to-a-long-random-string

# --- Manus OAuth (signed-in features) ---
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=
# First account with this Manus openId is promoted to admin on login
OWNER_OPEN_ID=

# --- SpaceXAI / xAI (AI tutor — preferred) ---
# Get a key: https://console.x.ai  ·  Docs: https://docs.x.ai
XAI_API_KEY=
# Optional overrides (defaults shown):
# XAI_BASE_URL=https://api.x.ai/v1
# XAI_MODEL=grok-4.5

# --- Legacy Manus Forge (storage / optional LLM fallback) ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
# OPENAI_API_KEY=  # treated as forge key fallback only

# Hangul Basics curriculum gate (default off). Set to "true" only after
# Basics UI + grandfather backfill ship. Server + client read via gateStatus.
# BASICS_GATE_ENABLED=false
