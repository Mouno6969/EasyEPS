  "grammar": [
    {
      "pattern": "V + (으)ㄹ 거예요",
      "titleBn": "ভবিষ্যৎ কাল",
      "explanationBn": "এই ব্যাকরণটি ভবিষ্যতের কোনো পরিকল্পনা বা কাজ বোঝাতে ব্যবহৃত হয়। ক্রিয়াপদের শেষে স্বরবর্ণ থাকলে '-ㄹ 거예요' এবং ব্যঞ্জনবর্ণ থাকলে '-을 거예요' যুক্ত হয়।",
      "explanationEn": "This grammar pattern is used to express future plans or actions. '-ㄹ 거예요' is added to verb stems ending in a vowel, and '-을 거예요' is added to verb stems ending in a consonant.",
      "examples": [
        {
          "ko": "내일 영화를 볼 거예요.",
          "bn": "আগামীকাল সিনেমা দেখব।",
          "en": "I will watch a movie tomorrow."
        },
        {
          "ko": "주말에 책을 읽을 거예요.",
          "bn": "সাপ্তাহিক ছুটিতে বই পড়ব।",
          "en": "I will read a book on the weekend."
        }
      ]
    },
    {
      "pattern": "V + 고 싶다",
      "titleBn": "ইচ্ছা প্রকাশ করা",
      "explanationBn": "এই ব্যাকরণটি কোনো কিছু করার ইচ্ছা প্রকাশ করতে ব্যবহৃত হয়। এটি ক্রিয়াপদের মূল অংশের সাথে যুক্ত হয়।",
      "explanationEn": "This grammar pattern is used to express a desire to do something. It is attached to the verb stem.",
