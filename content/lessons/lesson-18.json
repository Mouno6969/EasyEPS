  "grammar": [
    {
      "pattern": "V-(으)ㄹ 때",
      "titleBn": "সময় নির্দেশক (যখন)",
      "explanationBn": "কোনো কাজ বা ঘটনা ঘটার সময় বোঝাতে ক্রিয়াপদের সাথে '-(으)ㄹ 때' যুক্ত হয়। ক্রিয়াপদের শেষে ব্যঞ্জনবর্ণ থাকলে '-을 때' এবং স্বরবর্ণ বা 'ㄹ' থাকলে '-ㄹ 때' বসে।",
      "explanationEn": "Used to express the time when an action or state occurs. '-을 때' is used after a consonant, and '-ㄹ 때' is used after a vowel or 'ㄹ'.",
      "examples": [
        {
          "ko": "시간이 있을 때 낚시를 해요.",
          "bn": "সময় পেলে আমি মাছ ধরি।",
          "en": "When I have time, I go fishing."
        },
        {
          "ko": "기분이 좋을 때 노래를 불러요.",
          "bn": "মন ভালো থাকলে আমি গান গাই।",
          "en": "When I feel good, I sing a song."
        },
        {
          "ko": "비가 올 때 집에서 영화를 봐요.",
          "bn": "বৃষ্টি হলে আমি বাড়িতে সিনেমা দেখি।",
          "en": "When it rains, I watch movies at home."
        }
      ]
    },
    {
      "pattern": "V-(으)러 가다/오다",
      "titleBn": "উদ্দেশ্য নির্দেশক (কোনো কিছু করতে যাওয়া/আসা)",
      "explanationBn": "কোনো স্থানে যাওয়ার বা আসার উদ্দেশ্য বোঝাতে ক্রিয়াপ드의 সাথে '-(으)러 가다/오다' ব্যবহৃত হয়। ব্যঞ্জনবর্ণ থাকলে '-으러' এবং স্বরবর্ণ বা 'ㄹ' থাকলে '-러' বসে।",
      "explanationEn": "Used to express the purpose of going or coming to a place. '-으러' is used after a consonant, and '-러' is used after a vowel or 'ㄹ'.",
