  "grammar": [
    {
      "pattern": "N + 을/를",
      "titleBn": "অবজেক্ট মার্কার",
      "explanationBn": "বাক্যের কর্ম বা অবজেক্ট নির্দেশ করতে '을/를' ব্যবহৃত হয়। ব্যঞ্জনবর্ণ দিয়ে শেষ হলে '을' এবং স্বরবর্ণ দিয়ে শেষ হলে '를' বসে।",
      "explanationEn": "Object marker used to indicate the object of a sentence. '을' is used after a consonant, and '를' is used after a vowel.",
      "examples": [
        {
          "ko": "저는 밥을 먹습니다.",
          "bn": "আমি ভাত খাই।",
          "en": "I eat rice."
        },
        {
          "ko": "사과를 삽니다.",
          "bn": "আপেল কিনি।",
          "en": "I buy an apple."
        },
        {
          "ko": "물을 마십니다.",
          "bn": "পানি পান করি।",
          "en": "I drink water."
        }
      ],
      "commonMistakeBn": "অনেকে ব্যঞ্জনবর্ণ ও স্বরবর্ণের পার্থক্য না বুঝে ভুল মার্কার ব্যবহার করেন; মনে রাখবেন, ব্যঞ্জনবর্ণের পর '을' এবং স্বরবর্ণের পর '를' বসে।"
    },
    {
      "pattern": "V + (으)세요",
      "titleBn": "অনুরোধ বা নির্দেশ",
      "explanationBn": "কাউকে সম্মানজনকভাবে কোনো কিছু করতে অনুরোধ বা নির্দেশ দিতে এটি ব্যবহৃত হয়। ব্যঞ্জনবর্ণ দিয়ে শেষ হলে '으세요' এবং স্বরবর্ণ দিয়ে শেষ হলে '세요' বসে।",
      "explanationEn": "Used to politely request or instruct someone to do something. '으세요' is used after a consonant, and '세요' is used after a vowel.",
      "examples": [
        {
