  "grammar": [
    {
      "pattern": "N + 주세요",
      "titleBn": "দয়া করে দিন (অনুরোধ)",
      "explanationBn": "কোনো কিছু চাওয়ার বা অনুরোধ করার সময় বিশেষ্যের (Noun) সাথে '주세요' যুক্ত করা হয়। রেস্তোরাঁয় খাবার অর্ডার করার সময় এটি খুব বেশি ব্যবহৃত হয়।",
      "explanationEn": "Used to request or ask for something by attaching '주세요' to a noun. It is very commonly used when ordering food at a restaurant.",
      "examples": [
        {
          "ko": "물 좀 주세요.",
          "bn": "দয়া করে একটু পানি দিন।",
          "en": "Please give me some water."
        },
        {
          "ko": "비빔밥 하나 주세요.",
          "bn": "দয়া করে একটি বিবিমবাপ দিন।",
          "en": "Please give me one bibimbap."
        },
        {
          "ko": "메뉴판 좀 주세요.",
          "bn": "দয়া করে মেনুটি দিন।",
          "en": "Please give me the menu."
        }
      ]
    },
    {
      "pattern": "안 + V/A",
      "titleBn": "না-বোধক বাক্য (নেতিবাচক)",
      "explanationBn": "ক্রিয়া (Verb) বা বিশেষণের (Adjective) আগে '안' বসিয়ে বাক্যকে না-বোধক করা হয়। এটি 'না' বা 'নয়' অর্থ প্রকাশ করে।",
      "explanationEn": "Used to make a negative sentence by placing '안' before a verb or adjective. It means 'not' or 'do not'.",
      "examples": [
        {
          "ko": "저는 고기를 안 먹어요.",
          "bn": "আমি মাংস খাই না।",
          "en": "I do not eat meat."
        },
        {
          "ko": "이 김치는 안 매워요.",
          "bn": "এই কিমচি ঝাল নয়।",
          "en": "This kimchi is not spicy."
        },
        {
          "ko": "오늘 식당에 안 가요.",
          "bn": "আজ রেস্তোরাঁয় যাব না।",
          "en": "I am not going to the restaurant today."
        }
      ]
    }
  ],
  "dialogues": [
    {
      "titleBn": "খাবার অর্ডার করা",
      "titleEn": "Ordering Food",
      "lines": [
        {
          "speaker": "종업원",
          "ko": "어서 오세요. 몇 분이세요?",
          "bn": "স্বাগতম। আপনারা কতজন?",
          "en": "Welcome. How many people?"
        },
        {
          "speaker": "투안",
          "ko": "두 명이에요. 자리 있어요?",
          "bn": "আমরা দুজন। জায়গা আছে কি?",
          "en": "Two people. Are there any seats?"
        },
        {
          "speaker": "종업원",
          "ko": "네, 있어요. 이쪽으로 앉으세요. 뭐 드릴까요?",
          "bn": "হ্যাঁ, আছে। এদিকে বসুন। আপনাদের কী দেব?",
          "en": "Yes, there are. Please sit this way. What would you like?"
        },
        {
          "speaker": "투안",
          "ko": "저는 비빔밥 먹을래요.",
          "bn": "আমি বিবিমবাপ খাব।",
          "en": "I will have bibimbap."
        },
        {
          "speaker": "리한",
          "ko": "저는 김치찌개 먹을래요.",
          "bn": "আমি কিমচি চিগে খাব।",
          "en": "I will have kimchi stew."
        },
        {
          "speaker": "투안",
          "ko": "그럼 여기 비빔밥 하나하고 김치찌개 하나 주세요.",
          "bn": "তাহলে এখানে একটি বিবিমবাপ এবং একটি কিমচি চিগে দিন।",
          "en": "Then please give us one bibimbap and one kimchi stew here."
        }
      ]
    },
    {
      "titleBn": "খাবারের স্বাদ সম্পর্কে কথা বলা",
      "titleEn": "Talking about the Taste of Food",
      "lines": [
        {
          "speaker": "리한",
          "ko": "투안 씨, 김치찌개가 어때요?",
          "bn": "তুয়ান সাহেব, কিমচি চিগে কেমন?",
          "en": "Tuan, how is the kimchi stew?"
        },
        {
          "speaker": "투안",
          "ko": "조금 매워요. 하지만 맛있어요.",
          "bn": "একটু ঝাল। কিন্তু মজাদার।",
          "en": "It's a little spicy. But it's delicious."
        },
        {
          "speaker": "리한",
          "ko": "리한 씨는 김치찌개를 좋아해요?",
          "bn": "রিহান সাহেব কি কিমচি চিগে পছন্দ করেন?",
          "en": "Do you like kimchi stew, Rihan?"
        },
        {
          "speaker": "투안",
          "ko": "아니요, 저는 안 좋아해요. 저는 불고기를 좋아해요.",
          "bn": "না, আমি পছন্দ করি না। আমি বুলগোগি পছন্দ করি।",
          "en": "No, I don't like it. I like bulgogi."
        }
      ]
    }
