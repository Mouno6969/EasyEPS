  "grammar": [
    {
      "pattern": "V + (으)세요",
      "titleBn": "অনুরোধ বা নির্দেশ",
      "explanationBn": "কাউকে বিনীতভাবে কিছু করতে বলার জন্য বা নির্দেশ দেওয়ার জন্য এটি ব্যবহৃত হয়। ক্রিয়াপদের শেষে ব্যঞ্জনবর্ণ থাকলে '으세요' এবং স্বরবর্ণ থাকলে '세요' যুক্ত হয়।",
      "explanationEn": "Used to politely request or instruct someone to do something. Add '으세요' if the verb stem ends in a consonant, and '세요' if it ends in a vowel.",
      "examples": [
        {
          "ko": "여기에 앉으세요.",
          "bn": "এখানে বসুন।",
          "en": "Please sit here."
        },
        {
          "ko": "물을 끓이세요.",
          "bn": "পানি ফোটান।",
          "en": "Please boil the water."
        },
        {
          "ko": "양파를 썰으세요.",
          "bn": "পেঁয়াজ কাটুন।",
          "en": "Please chop the onion."
        }
      ]
    },
    {
      "pattern": "A/V + 지 않다",
      "titleBn": "নেতিবাচক রূপ",
      "explanationBn": "এটি বিশেষণ বা ক্রিয়াপদের নেতিবাচক রূপ তৈরি করতে ব্যবহৃত হয়। এর অর্থ 'না' বা 'নয়'।",
      "explanationEn": "Used to make the negative form of an adjective or verb. It means 'not'.",
      "examples": [
        {
          "ko": "이 음식은 맵지 않아요.",
          "bn": "এই খাবারটি ঝাল নয়।",
          "en": "This food is not spicy."
        },
        {
          "ko": "저는 고기를 먹지 않아요.",
          "bn": "আমি মাংস খাই না।",
          "en": "I do not eat meat."
        },
        {
          "ko": "오늘은 바쁘지 않아요.",
          "bn": "আজ ব্যস্ত নই।",
          "en": "I am not busy today."
        }
      ]
    }
  ],
  "dialogues": [
    {
      "titleBn": "রান্না করা",
      "titleEn": "Cooking",
      "lines": [
        {
          "speaker": "수루",
          "ko": "투안 씨, 김치찌개를 만들 줄 알아요?",
          "bn": "তুয়ান সাহেব, আপনি কি কিমচি চিগে বানাতে জানেন?",
          "en": "Tuan, do you know how to make Kimchi Jjigae?"
        },
        {
          "speaker": "투안",
          "ko": "네, 만들 줄 알아요. 아주 쉬워요.",
          "bn": "হ্যাঁ, বানাতে জানি। এটা খুব সহজ।",
          "en": "Yes, I know how to make it. It's very easy."
        },
        {
          "speaker": "수루",
          "ko": "그럼 어떻게 만들어요?",
          "bn": "তাহলে কীভাবে বানায়?",
          "en": "Then how do you make it?"
        },
        {
          "speaker": "투안",
          "ko": "먼저 냄비에 김치와 돼지고기를 넣고 볶으세요.",
          "bn": "প্রথমে হাঁড়িতে কিমচি এবং শুকরের মাংস দিয়ে ভাজুন।",
          "en": "First, put kimchi and pork in a pot and stir-fry them."
        },
        {
          "speaker": "수루",
          "ko": "그리고 물을 넣고 끓여요?",
          "bn": "তারপর পানি দিয়ে ফোটাবো?",
          "en": "And then add water and boil it?"
        },
        {
          "speaker": "투안",
          "ko": "네, 맞아요. 물이 끓으면 파를 넣으세요.",
          "bn": "হ্যাঁ, ঠিক বলেছেন। পানি ফুটলে পেঁয়াজ পাতা দিন।",
          "en": "Yes, that's right. When the water boils, add green onions."
        }
      ]
    },
