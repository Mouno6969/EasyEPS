  "grammar": [
    {
      "pattern": "~아/어 주세요",
      "titleBn": "অনুরোধ করা",
      "explanationBn": "এই আচরণ বাক্যটি কাউকে বিনীতভাবে কিছু করার অনুরোধ করতে ব্যবহার হয়। উদাহরণ এবং অনুবাদসহ: 1) 사료를 주세요. - দয়া করে ফিড দিন। - Please give the feed. 2) 물을 채워 주세요. - পানি ভর্তি করে দিন। - Please fill the water.",
      "explanationEn": "Use ~아/어 주세요 to politely ask someone to do something. Examples with translations: 1) 사료를 주세요. - Please give the feed. 2) 물을 채워 주세요. - Please fill the water.",
      "examples": [
        {
          "ko": "울타리를 고쳐 주세요.",
          "bn": "বেড়া ঠিক করে দিন দয়া করে।",
          "en": "Please repair the fence."
        },
        {
          "ko": "병을 수의사에게 가져다 주세요.",
          "bn": "রোগীটাকে পশুচিকিৎসকের কাছে নিয়ে যান।",
          "en": "Please take the sick animal to the vet."
        }
      ]
    },
    {
      "pattern": "~아/어야 하다",
      "titleBn": "করণীয়তা/দায়িত্ব",
      "explanationBn": "কিছু করা আবশ্যক বোঝাতে ব্যবহার হয়। উদাহরণ: 1) 착유를 해야 합니다. - আপনাকে দুধ দিতে হবে। 2) 백신을 맞혀야 해요. - টিকা দেবই।",
      "explanationEn": "Use ~아/어야 하다 to express obligation or necessity. Examples: 1) 착유를 해야 합니다. - You must milk. 2) 백신을 맞혀야 해요. - You have to vaccinate.",
      "examples": [
        {
          "ko": "축사를 청소해야 합니다.",
          "bn": "স্টেবল পরিষ্কার করা দরকার।",
          "en": "You must clean the barn."
        },
        {
          "ko": "방역을 해야 합니다.",
          "bn": "প্রতিষেধ ব্যবস্থা করতে হবে।",
          "en": "We must carry out disinfection/quarantine."
        }
      ]
    },
    {
      "pattern": "~고 있습니다",
      "titleBn": "বর্তমান ক্রিয়া (চলমান)",
      "explanationBn": "এই রূপটি বলে যে কাজটি বর্তমানে চলছে। উদাহরণ: 1) 소를 방목하고 있습니다. - গরু এখন চারায় আছে। 2) 수의사가 검사하고 있습니다. - পশুচিকিৎসক পরীক্ষা করছেন।",
      "explanationEn": "Use ~고 있습니다 to indicate an action in progress. Examples: 1) 소를 방목하고 있습니다. - The cows are grazing now. 2) 수의사가 검사하고 있습니다. - The vet is examining.",
      "examples": [
        {
          "ko": "사료를 주고 있습니다.",
          "bn": "আমি এখন ফিড দিচ্ছি।",
          "en": "I am feeding now."
        },
        {
          "ko": "물을 보충하고 있습니다.",
          "bn": "পানি এখন ভরাট করা হচ্ছে।",
          "en": "Water is being refilled."
        }
      ]
    }
