  "grammar": [
    {
      "pattern": "V + 아/어 보다",
      "titleBn": "অভিজ্ঞতা প্রকাশ (아/어 보다)",
      "explanationBn": "ক্রিয়ার সাথে যুক্ত হয়ে কোনো কাজ করার অভিজ্ঞতা বোঝায়। এর অর্থ 'কোনো কিছু করে দেখা'।",
      "explanationEn": "Attached to a verb to express an experience of doing something. It means 'to try doing something'.",
      "examples": [
        {
          "ko": "제주도에 가 봤어요.",
          "bn": "আমি জেজু দ্বীপে গিয়েছি (যাওয়ার অভিজ্ঞতা আছে)।",
          "en": "I have been to Jeju Island."
        },
        {
          "ko": "불고기를 먹어 봤어요.",
          "bn": "আমি বুলগোগি খেয়ে দেখেছি।",
          "en": "I have tried eating Bulgogi."
        },
        {
          "ko": "한복을 입어 봤어요?",
          "bn": "আপনি কি হানবক পরে দেখেছেন?",
          "en": "Have you tried wearing Hanbok?"
        }
      ]
    },
    {
      "pattern": "V + (으)ㄹ 거예요",
      "titleBn": "ভবিষ্যৎ কাল ((으)ㄹ 거예요)",
      "explanationBn": "ক্রিয়ার সাথে যুক্ত হয়ে ভবিষ্যৎ পরিকল্পনা বা ইচ্ছা প্রকাশ করে। ব্যঞ্জনবর্ণ দিয়ে শেষ হলে '을 거예요' এবং স্বরবর্ণ দিয়ে শেষ হলে 'ㄹ 거예요' বসে।",
      "explanationEn": "Attached to a verb to express a future plan or intention. '을 거예요' is used after a consonant, and 'ㄹ 거예요' is used after a vowel.",
      "examples": [
        {
          "ko": "내일 부산에 갈 거예요.",
          "bn": "আগামীকাল বুসানে যাব।",
          "en": "I will go to Busan tomorrow."
        },
        {
          "ko": "주말에 집에서 쉴 거예요.",
          "bn": "সপ্তাহান্তে বাড়িতে বিশ্রাম নেব।",
          "en": "I will rest at home on the weekend."
        },
        {
          "ko": "이번 휴가에 무엇을 할 거예요?",
          "bn": "এই ছুটিতে কী করবেন?",
          "en": "What will you do this vacation?"
        }
      ]
    }
  ],
