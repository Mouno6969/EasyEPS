  "grammar": [
    {
      "pattern": "N + 이/가",
      "titleBn": "সাবজেক্ট মার্কার (Subject Marker)",
      "explanationBn": "বাক্যের কর্তাকে (subject) নির্দেশ করতে বিশেষ্যের (noun) সাথে '이' বা '가' যুক্ত হয়। বিশেষ্যটি ব্যঞ্জনবর্ণ দিয়ে শেষ হলে '이' এবং স্বরবর্ণ দিয়ে শেষ হলে '가' বসে।",
      "explanationEn": "Attached to a noun to indicate the subject of the sentence. '이' is used after a consonant, and '가' is used after a vowel.",
      "examples": [
        {
          "ko": "가방이 있습니다.",
          "bn": "ব্যাগ আছে।",
          "en": "There is a bag."
        },
        {
          "ko": "열쇠가 없습니다.",
          "bn": "চাবি নেই।",
          "en": "There is no key."
        }
      ]
    },
    {
      "pattern": "N + 에 있습니다/없습니다",
      "titleBn": "অবস্থান নির্দেশক (Location/Existence)",
      "explanationBn": "কোনো জিনিস বা ব্যক্তি কোথায় আছে বা নেই তা বোঝাতে স্থানের নামের সাথে '에' যুক্ত করে '있습니다' (আছে) বা '없습니다' (নেই) ব্যবহার করা হয়।",
      "explanationEn": "Used to express the existence or location of an object or person. '에' is attached to a place noun, followed by '있습니다' (exists/is present) or '없습니다' (does not exist/is not present).",
      "examples": [
        {
          "ko": "지갑이 가방 안에 있습니다.",
          "bn": "মানিব্যাগটি ব্যাগের ভিতরে আছে।",
          "en": "The wallet is in the bag."
        },
        {
          "ko": "방에 시계가 없습니다.",
          "bn": "রুমে ঘড়ি নেই।",
          "en": "There is no clock in the room."
        }
      ]
    }
  ],
