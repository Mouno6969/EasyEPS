  "grammar": [
    {
      "pattern": "V/A + 아요/어요",
      "titleBn": "অনানুষ্ঠানিক ভদ্রসূচক সমাপ্তি",
      "explanationBn": "এটি কোরিয়ান ভাষার একটি সাধারণ এবং অনানুষ্ঠানিক ভদ্রসূচক বাক্য সমাপ্তি। ক্রিয়াপদ বা বিশেষণের মূল অংশের শেষ স্বরবর্ণ যদি 'ㅏ' বা 'ㅗ' হয়, তবে '-아요' যুক্ত হয়। অন্য স্বরবর্ণ হলে '-어요' যুক্ত হয়। '하다' থাকলে তা '해요' হয়ে যায়।",
      "explanationEn": "This is a common informal polite sentence ending in Korean. If the last vowel of the verb or adjective stem is 'ㅏ' or 'ㅗ', '-아요' is added. For other vowels, '-어요' is added. '하다' becomes '해요'.",
      "examples": [
        {
          "ko": "저는 아침을 먹어요.",
          "bn": "আমি সকালের নাস্তা খাই।",
          "en": "I eat breakfast."
        },
        {
          "ko": "텔레비전을 봐요.",
          "bn": "টেলিভিশন দেখি।",
          "en": "I watch television."
        },
        {
          "ko": "매일 운동해요.",
          "bn": "প্রতিদিন ব্যায়াম করি।",
          "en": "I exercise every day."
        }
      ]
    },
    {
      "pattern": "N + 에",
      "titleBn": "সময় নির্দেশক কণা",
      "explanationBn": "এটি সময়ের সাথে যুক্ত হয়ে কোনো কাজ কখন ঘটে তা নির্দেশ করে। এটি বাংলা 'এ' বা 'তে' বিভক্তির মতো কাজ করে। তবে '오늘' (আজ), '내일' (আগামীকাল), '어제' (গতকাল), '지금' (এখন) ইত্যাদির সাথে এটি যুক্ত হয় না।",
      "explanationEn": "This particle is attached to time nouns to indicate when an action takes place. It is not used with words like '오늘' (today), '내일' (tomorrow), '어제' (yesterday), or '지금' (now).",
      "examples": [
