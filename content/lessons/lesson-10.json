  "grammar": [
    {
      "pattern": "V/A + 아/어/여요",
      "titleBn": "সাধারণ বর্তমান কাল (ভদ্রসূচক)",
      "explanationBn": "এটি কোরিয়ান ভাষার সবচেয়ে সাধারণ বর্তমান কালের রূপ। ক্রিয়ামূলের শেষ স্বরবর্ণ 'ㅏ' বা 'ㅗ' হলে '아요' যুক্ত হয়। অন্য স্বরবর্ণ হলে '어요' যুক্ত হয়। '하다' থাকলে '해요' হয়।",
      "explanationEn": "This is the most common polite present tense form. If the verb stem ends in 'ㅏ' or 'ㅗ', '아요' is added. For other vowels, '어요' is added. '하다' becomes '해요'.",
      "examples": [
        {
          "ko": "사과를 사요.",
          "bn": "আপেল কিনি।",
          "en": "I buy apples."
        },
        {
          "ko": "옷이 비싸요.",
          "bn": "কাপড় দামি।",
          "en": "The clothes are expensive."
        },
        {
          "ko": "시장에서 쇼핑해요.",
          "bn": "বাজার থেকে কেনাকাটা করি।",
          "en": "I shop at the market."
        }
      ]
    },
    {
      "pattern": "N + 주세요",
      "titleBn": "অনুরোধ করা (দিন)",
      "explanationBn": "কোনো কিছু চাওয়ার সময় বা অনুরোধ করার সময় বিশেষ্যের সাথে '주세요' ব্যবহার করা হয়। এর অর্থ 'দয়া করে দিন'।",
      "explanationEn": "Used with a noun to request something. It means 'please give me'.",
      "examples": [
        {
          "ko": "물 좀 주세요.",
          "bn": "একটু পানি দিন।",
          "en": "Please give me some water."
        },
        {
          "ko": "이 사과 다섯 개 주세요.",
          "bn": "এই আপেল পাঁচটি দিন।",
          "en": "Please give me five of these apples."
        }
      ]
    }
  ],
