  "grammar": [
    {
      "pattern": "N + 하고 / (이)랑",
      "titleBn": "এবং / সাথে",
      "explanationBn": "বিশেষ্যের সাথে যুক্ত হয়ে 'এবং' বা 'সাথে' অর্থ প্রকাশ করে। এটি সাধারণত কথোপকথনে বেশি ব্যবহৃত হয়।",
      "explanationEn": "Attached to a noun to mean 'and' or 'with'. It is mostly used in spoken language.",
      "examples": [
        {
          "ko": "아버지하고 어머니가 계십니다.",
          "bn": "বাবা এবং মা আছেন।",
          "en": "I have a father and a mother."
        },
        {
          "ko": "친구하고 같이 밥을 먹어요.",
          "bn": "বন্ধুর সাথে একসাথে ভাত খাই।",
          "en": "I eat with my friend."
        },
        {
          "ko": "형이랑 동생이 있어요.",
          "bn": "বড় ভাই এবং ছোট ভাই/বোন আছে।",
          "en": "I have an older brother and a younger sibling."
        }
      ]
    },
    {
      "pattern": "N + 에 살다",
      "titleBn": "কোনো স্থানে বাস করা",
      "explanationBn": "কোনো নির্দিষ্ট স্থানে বাস করা বোঝাতে স্থানের নামের পর '에' যুক্ত করে '살다' (বাস করা) ব্যবহৃত হয়।",
      "explanationEn": "Used to indicate living in a specific place. '에' is attached to the place noun followed by '살다' (to live).",
      "examples": [
        {
          "ko": "가족은 방글라데시에 살아요.",
          "bn": "পরিবার বাংলাদেশে বাস করে।",
          "en": "My family lives in Bangladesh."
        },
        {
          "ko": "저는 서울에 살아요.",
          "bn": "আমি সিউলে বাস করি।",
          "en": "I live in Seoul."
        }
      ]
    }
  ],
