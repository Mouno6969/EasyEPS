  "grammar": [
    {
      "pattern": "—고 있다",
      "titleBn": "—고 있다 (চলমান ক্রিয়া)",
      "explanationBn": "현재 কোনো কাজ ঘটছে তা বোঝায়। উদাহরণ এবং অনুবাদ: 1) 기계가 작동하고 있다. — মেশিন কাজ করছে। 2) 우리는 원단을 검사하고 있다. — আমরা ফ্যাব্রিক পরীক্ষা করছি।",
      "explanationEn": "Used to express an action in progress. Examples: 1) 기계가 작동하고 있다. — The machine is operating. 2) 우리는 원단을 검사하고 있다. — We are inspecting the fabric.",
      "examples": [
        {
          "ko": "기계가 작동하고 있다.",
          "bn": "মেশিন কাজ করছে।",
          "en": "The machine is operating."
        },
        {
          "ko": "직원들이 원단을 검사하고 있다.",
          "bn": "কর্মীরা ফ্যাব্রিক পরীক্ষা করছে।",
          "en": "Workers are inspecting the fabric."
        }
      ]
    },
    {
      "pattern": "—(으)세요",
