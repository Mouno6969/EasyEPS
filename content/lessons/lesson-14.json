  "grammar": [
    {
      "pattern": "N + (으)로",
      "titleBn": "দিক বা গন্তব্য নির্দেশক",
      "explanationBn": "কোনো নির্দিষ্ট দিক বা গন্তব্যের দিকে যাওয়া বোঝাতে বিশেষ্যের সাথে '(으)로' যুক্ত হয়। বিশেষ্যটি ব্যঞ্জনবর্ণ দিয়ে শেষ হলে '으로' এবং স্বরবর্ণ বা 'ㄹ' দিয়ে শেষ হলে '로' বসে।",
      "explanationEn": "Used to indicate direction or destination. '으로' is used after a consonant, and '로' is used after a vowel or 'ㄹ'.",
      "examples": [
        {
          "ko": "오른쪽으로 가세요.",
          "bn": "ডান দিকে যান।",
          "en": "Go to the right."
        },
        {
          "ko": "앞으로 가세요.",
          "bn": "সামনের দিকে যান।",
          "en": "Go forward."
        },
        {
          "ko": "서울로 가요.",
          "bn": "সিউলের দিকে যাই।",
          "en": "I am going to Seoul."
        }
      ]
    },
    {
      "pattern": "N + 에 있다/없다",
      "titleBn": "অবস্থান নির্দেশক",
      "explanationBn": "কোনো ব্যক্তি বা বস্তুর অবস্থান বোঝাতে জায়গার নামের সাথে '에' যুক্ত হয়ে '있다' (আছে) বা '없다' (নেই) ব্যবহৃত হয়।",
      "explanationEn": "Used to indicate the location of a person or object. '에' is attached to a place noun followed by '있다' (to exist/be) or '없다' (not to exist/not to be).",
      "examples": [
        {
          "ko": "은행이 병원 옆에 있어요.",
          "bn": "ব্যাংকটি হাসপাতালের পাশে আছে।",
          "en": "The bank is next to the hospital."
        },
        {
          "ko": "약국이 이 근처에 없어요.",
          "bn": "এই আশেপাশে কোনো ফার্মেসি নেই।",
          "en": "There is no pharmacy nearby."
        },
        {
          "ko": "가방이 책상 위에 있어요.",
          "bn": "ব্যাগটি টেবিলের উপরে আছে।",
          "en": "The bag is on the desk."
        }
      ]
    }
  ],
