  "grammar": [
    {
      "pattern": "N + 에",
      "titleBn": "সময় নির্দেশক '에'",
      "explanationBn": "সময়ের সাথে '에' যুক্ত হয়ে বোঝায় যে কোনো কাজ কখন ঘটছে। এটি বাংলা 'এ' বা 'তে' বিভক্তির মতো কাজ করে। তবে '오늘' (আজ), '내일' (আগামীকাল), '어제' (গতকাল) ইত্যাদির সাথে '에' বসে না।",
      "explanationEn": "The particle '에' is attached to time nouns to indicate when an action takes place. It is not used with words like 오늘 (today), 내일 (tomorrow), or 어제 (yesterday).",
      "examples": [
        {
          "ko": "월요일에 만나요.",
          "bn": "সোমবারে দেখা হবে।",
          "en": "See you on Monday."
        },
        {
          "ko": "주말에 쉬어요.",
          "bn": "সপ্তাহান্তে বিশ্রাম নিই।",
          "en": "I rest on the weekend."
        },
        {
          "ko": "내일 만나요.",
          "bn": "আগামীকাল দেখা হবে।",
          "en": "See you tomorrow."
        }
      ]
    },
    {
      "pattern": "무슨 N",
      "titleBn": "কী ধরনের / কোন (무슨)",
      "explanationBn": "'무슨' শব্দটি বিশেষ্যের আগে বসে 'কী ধরনের' বা 'কোন' বোঝাতে ব্যবহৃত হয়। সপ্তাহের দিন জিজ্ঞেস করতে '무슨 요일' (কী বার) ব্যবহৃত হয়।",
      "explanationEn": "'무슨' is placed before a noun to mean 'what kind of' or 'which'. To ask the day of the week, '무슨 요일' (what day) is used.",
      "examples": [
        {
          "ko": "오늘이 무슨 요일입니까?",
          "bn": "আজ কী বার?",
          "en": "What day of the week is it today?"
        },
        {
          "ko": "무슨 일을 하십니까?",
          "bn": "আপনি কী কাজ করেন?",
          "en": "What kind of work do you do?"
        }
      ]
    },
    {
      "pattern": "몇 월 며칠",
      "titleBn": "কোন মাস, কত তারিখ",
      "explanationBn": "তারিখ জিজ্ঞেস করার জন্য '몇 월 며칠' (কত মাস, কত তারিখ) ব্যবহৃত হয়। কোরিয়ান ভাষায় মাস এবং তারিখ বলার সময় সিনো-কোরিয়ান সংখ্যা (일, 이, 삼...) ব্যবহৃত হয়।",
      "explanationEn": "'몇 월 며칠' is used to ask the date (what month and what date). Sino-Korean numbers are used when saying months and dates.",
      "examples": [
        {
          "ko": "오늘이 몇 월 며칠입니까?",
          "bn": "আজ কত তারিখ?",
          "en": "What is the date today?"
        },
        {
          "ko": "생일이 몇 월 며칠입니까?",
          "bn": "আপনার জন্মদিন কবে?",
          "en": "When is your birthday?"
        }
      ]
    }
  ],
