  "grammar": [
    {
      "pattern": "N + 에",
      "titleBn": "অবস্থান নির্দেশক '에'",
      "explanationBn": "কোরিয়ান ভাষায় কোনো স্থান বা অবস্থান বোঝাতে বিশেষ্যের (Noun) সাথে '에' যুক্ত করা হয়। এটি বাংলায় 'এ' বা 'তে' বিভক্তির মতো কাজ করে।",
      "explanationEn": "Used with a noun to indicate a location or destination. It functions like 'at', 'in', or 'to' in English.",
      "examples": [
        {
          "ko": "저는 학교에 갑니다.",
          "bn": "আমি বিদ্যালয়ে যাই।",
          "en": "I go to school."
        },
        {
          "ko": "친구가 병원에 있습니다.",
          "bn": "বন্ধু হাসপাতালে আছে।",
          "en": "My friend is at the hospital."
        }
      ]
    },
    {
      "pattern": "N + 에 있다/없다",
      "titleBn": "অবস্থান প্রকাশ করা (있다/없다)",
      "explanationBn": "কোনো ব্যক্তি বা বস্তু কোনো স্থানে আছে (있다) বা নেই (없다) তা বোঝাতে এই প্যাটার্নটি ব্যবহৃত হয়।",
      "explanationEn": "Used to express the existence or non-existence of someone or something at a specific location.",
      "examples": [
        {
          "ko": "책상 위에 책이 있습니다.",
          "bn": "টেবিলের উপরে বই আছে।",
          "en": "There is a book on the desk."
        },
        {
          "ko": "방 안에 사람이 없습니다.",
          "bn": "রুমের ভিতরে মানুষ নেই।",
          "en": "There is no one in the room."
        }
      ]
    }
  ],
